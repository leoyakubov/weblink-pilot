# Optional Brevo SMTP override for manual local and demo testing.
# Copy this file to backend/.env.smtp.local and fill in the credentials.

APP_AUTH_MAIL_DELIVERY_MODE=SMTP
SPRING_MAIL_FROM_ADDRESS=no-reply@weblinkpilot.local
SPRING_MAIL_FROM_NAME=WebLinkPilot
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=change-me
SPRING_MAIL_PASSWORD=change-me
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true
