# Optional Mailtrap SMTP override for manual local testing.
# Copy this file to backend/.env.smtp.local and fill in the credentials.

SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=change-me
SPRING_MAIL_PASSWORD=change-me
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true
