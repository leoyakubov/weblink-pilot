# Local backend values.
# Copy this file to backend/.env and fill in your local values.
# The backend reads APP_AUTH_JWT_SECRET first, then JWT_SECRET.
# Either variable works for local/dev runs; demo and production still need a real secret.

JWT_SECRET=change-me

APP_AUTH_MAIL_DELIVERY_MODE=SMTP
APP_AUTH_ACCOUNT_ACTION_REQUEST_COOLDOWN_SECONDS=30
SPRING_MAIL_FROM_ADDRESS=no-reply@weblinkpilot.local
SPRING_MAIL_FROM_NAME=WeblinkPilot

# Local/dev launchers always force Mailpit:
# - SMTP: localhost:1025
# - UI: http://localhost:8025
# Demo/demo-local launchers use Brevo and read only the credentials below.
SPRING_MAIL_USERNAME=your_brevo_smtp_username_here
SPRING_MAIL_PASSWORD=your_brevo_smtp_password_here

# Optional GitHub OAuth login.
# Create a GitHub OAuth app with callback:
# http://localhost:8080/api/v1/auth/oauth2/github/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
APP_GITHUB_SCOPE=read:user user:email
APP_GITHUB_AUTHORIZATION_URL=https://github.com/login/oauth/authorize
APP_GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
APP_GITHUB_API_BASE_URL=https://api.github.com
APP_GITHUB_API_VERSION=2022-11-28
APP_GITHUB_USER_AGENT=WeblinkPilot
APP_GITHUB_TIMEOUT=10s
APP_GITHUB_ALLOW_SIGNUP=false
APP_GITHUB_STATE_ENTROPY_BYTES=32

# Optional local throttling overrides.
APP_CACHE_DEFAULT_TTL=10m
APP_CACHE_SHORT_LINKS_TTL=30m
APP_CACHE_ANALYTICS_TTL=30s
APP_RATE_LIMIT_API_PER_MINUTE=120
APP_RATE_LIMIT_REDIRECT_PER_MINUTE=300
APP_RATE_LIMIT_AUTH_PER_MINUTE=20
APP_SECURITY_PUBLIC_OBSERVABILITY=false
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:8081,http://127.0.0.1:8081

# Optional short-link behavior overrides.
APP_SHORT_LINK_ALIAS_MIN_LENGTH=3
APP_SHORT_LINK_ALIAS_MAX_LENGTH=64
APP_SHORT_LINK_ALIAS_ALLOWED_PATTERN='^[A-Za-z0-9_-]+$'
APP_SHORT_LINK_BROWSE_DEFAULT_LIMIT=10
APP_SHORT_LINK_BROWSE_MAX_LIMIT=50
APP_SHORT_LINK_CODE_LENGTH=7
APP_SHORT_LINK_CODE_MAX_GENERATION_ATTEMPTS=10
APP_SHORT_LINK_QR_SIZE=320
APP_SHORT_LINK_QR_MARGIN=2
APP_SHORT_LINK_QR_IMAGE_FORMAT=PNG

# Optional AI link enrichment.
# Defaults are safe for local/demo: no external API calls, deterministic stub metadata.
APP_AI_ENABLED=true
APP_AI_PROVIDER=stub
APP_AI_PROMPT_VERSION=link-metadata-v1
APP_AI_MAX_ATTEMPTS=2
APP_AI_OLLAMA_BASE_URL=http://localhost:11434
APP_AI_OLLAMA_MODEL=llama3.2:1b
APP_AI_OLLAMA_TIMEOUT=60s
APP_AI_OPENAI_BASE_URL=https://api.openai.com/v1
APP_AI_OPENAI_API_KEY=
APP_AI_OPENAI_MODEL=gpt-4o-mini
APP_AI_OPENAI_TIMEOUT=30s
