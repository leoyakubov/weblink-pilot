root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{xml,html}]
indent_style = space
indent_size = 4

[*.{js,ts,tsx,vue,json}]
indent_style = space
indent_size = 2

[*.java]
indent_style = space
indent_size = 4
