{
  "name": "weblink-pilot-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/run-build.mjs",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "audit": "npm audit --audit-level=high",
    "test": "node scripts/run-vitest.mjs",
    "test:run": "node scripts/run-vitest.mjs",
    "test:coverage": "node scripts/run-vitest.mjs --coverage",
    "smoke:docker": "node scripts/smoke-docker.mjs"
  },
  "dependencies": {
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^26.1.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  }
}
